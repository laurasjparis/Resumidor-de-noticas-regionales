# Copiar como .env y ajustar valores

# Base de datos — SQLite por defecto, cambiar a PostgreSQL en producción
DATABASE_URL=sqlite:///./noticias.db
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/noticias_db

APP_ENV=development
LOG_LEVEL=INFO

# Timeout en segundos para descargar artículos completos
HTTP_TIMEOUT=10

# Resultados máximos por página
MAX_NOTICIAS_PER_PAGE=50
