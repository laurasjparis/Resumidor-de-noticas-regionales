# Copiar como .env y ajustar valores

# --- Base de datos ---
# Docker (PostgreSQL)
DATABASE_URL=postgresql://noticias:noticias123@db:5432/noticias_db

# Local sin Docker (SQLite)
# DATABASE_URL=sqlite:///./noticias.db

# --- PostgreSQL (solo para docker-compose) ---
POSTGRES_USER=noticias
POSTGRES_PASSWORD=noticias123
POSTGRES_DB=noticias_db

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
HTTP_TIMEOUT=10
MAX_NOTICIAS_PER_PAGE=50
